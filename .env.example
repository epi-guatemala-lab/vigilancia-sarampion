# Método de envío: "api" (recomendado), "script", o "sheets"
VITE_SHEETS_METHOD=api

# Backend FastAPI (Opción A - recomendada)
VITE_API_URL=https://igss.mediclic.org/sarampion

# Google Apps Script (Opción B)
VITE_APPS_SCRIPT_URL=

# Google Sheets API (Opción C)
VITE_GOOGLE_SHEETS_ID=
VITE_GOOGLE_API_KEY=

# Base path para GitHub Pages
VITE_BASE_PATH=/vigilancia-sarampion/
