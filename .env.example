# Método de envío: "api" para Google Sheets API, "script" para Apps Script
VITE_SHEETS_METHOD=script

# Google Sheets API (Opción A)
VITE_GOOGLE_SHEETS_ID=tu_spreadsheet_id_aqui
VITE_GOOGLE_API_KEY=tu_api_key_aqui
VITE_GOOGLE_SERVICE_ACCOUNT_EMAIL=tu_service_account@proyecto.iam.gserviceaccount.com
VITE_GOOGLE_PRIVATE_KEY=tu_private_key_aqui

# Google Apps Script (Opción B - recomendada)
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/tu_deployment_id/exec

# Base path para GitHub Pages
VITE_BASE_PATH=/vigilancia-sarampion/
